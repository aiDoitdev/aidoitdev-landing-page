# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# External Links (Optional - defaults are provided)
NEXT_PUBLIC_CALENDAR_URL=https://cal.com/aidoit.dev/mvp
NEXT_PUBLIC_TWITTER_URL=https://x.com/Aidoit_dev
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com
NEXT_PUBLIC_GITHUB_URL=https://github.com

# Google Analytics (Optional)
NEXT_PUBLIC_GTM_ID=G-XXXXXXXXXX

# Application Environment
NODE_ENV=development
